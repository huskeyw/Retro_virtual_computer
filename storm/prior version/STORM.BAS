1 REM  STORM-VDP.BAS - SPRITE VERSION
2 REM  TILES: 0=SHIP 1=METEOR 2=BULLET 3=SAUCER 4=EXPL1 5=EXPL2 6=STARS 7=WALL
3 GOSUB 4000
5 CLS
10 REM   --- CONSTANTS ---
11 SS=8192:REM   SMALL SPRITE TABLE
12 TM=9216:REM   TILEMAP BASE
13 TB=10240:REM   TILE DATA BASE
14 VB=49280:REM   VDP BASE
15 SB=49200:REM   SOUND BASE
16 JY=49184:REM   JOYSTICK 1
17 SC=1024:REM   SCREEN RAM
18 CR=55296:REM   COLOR RAM
20 LX=168:REM   LEFT BOUNDARY
21 RX=472:REM   RIGHT BOUNDARY
22 REM   EACH SPRITE = 8 BYTES IN TABLE
30 REM   --- COLLISION REGISTERS ---
31 C13=49297:REM   METEORS HIT PLAYER
32 C23=49299:REM   BULLETS HIT METEORS
33 C24=49300:REM   BULLETS HIT SAUCER
34 H23=49307:REM   HIT INDEX BULLET/METEOR
35 H24=49308:REM   HIT INDEX BULLET/SAUCER
36 H13=49305:REM   HIT INDEX METEOR/PLAYER
40 REM   --- GAME ARRAYS ---
41 DIM MX(9):DIM MY(9):DIM MA(9):DIM MS(9)
42 DIM BX(4):DIM BY(4):DIM BA(4)
50 REM   --- GAME VARS ---
51 LV=1:LV3=3:SCC=0:NXT=5
52 SPD=0.04
53 PX=320:PY=360
54 SHX=0:SHD=1:SHA=0:SHT=30
60 REM   --- INIT ---
61 DLOAD "TILES.BIN",10240
62 GOSUB 5000:REM   INIT TILEMAP
63 GOSUB 5100:REM   INIT SPRITES
64 GOSUB 5200:REM   INIT SOUND
65 GOSUB 1400:REM   SPAWN METEORS
66 GOSUB 500:REM   DRAW HUD
67 POKE 49155,0
68 FOR R=0 TO 49:POKE SC + R * 80 + 20,98:POKE CR + R * 80 + 20,1:POKE SC + R * 80 + 59,98:POKE CR + R * 80 + 59,1:NEXT R
69 POKE VB,1
70 POKE VB + 3,1
71 POKE VB + 7,0
80 GOTO 200
100 REM   --- MAIN LOOP ---
200 REM   BONUS SHIP TIMER
201 SHT=SHT - 1
202 IF SHT <= 0 AND SHA = 0 THEN GOSUB 1100
203 IF SHA = 1 THEN GOSUB 1150
210 REM   JOYSTICK
211 J=PEEK(JY)
212 IF J AND 4 THEN GOSUB 900
213 IF J AND 8 THEN GOSUB 950
214 IF J AND 16 THEN GOSUB 850
220 REM   MOVE BULLETS
221 FOR J=0 TO 4
222 IF BA(J) = 0 THEN GOTO 240
223 BY(J)=BY(J) - 4
224 IF BY(J) < 32 THEN BA(J)=0:O=J + 11 * 8:POKE SS + O + 6,0:GOTO 240
225 O=J + 11 * 8:POKE SS + O + 0,BX(J) AND 255:POKE SS + O + 1,INT(BX(J) / 256):POKE SS + O + 2,BY(J) AND 255:POKE SS + O + 3,INT(BY(J) / 256):POKE SS + O + 4,2:POKE SS + O + 5,1:POKE SS + O + 6,81
240 NEXT J
250 REM   MOVE METEORS
251 FOR I=0 TO LV - 1
252 IF MA(I) = 0 THEN GOTO 290
253 IF MA(I) > 1 THEN MA(I)=MA(I) - 1:GOTO 290
254 MY(I)=MY(I) + MS(I)
260 REM   CHECK COLLISIONS VIA REGISTERS AFTER DRAW
270 IF MY(I) >= 370 AND MX(I) >= PX - 8 AND MX(I) <= PX + 8 THEN GOSUB 700:GOTO 290
271 IF MY(I) >= 380 THEN GOSUB 760:GOTO 290
275 GOSUB 3010
290 NEXT I
295 REM   CHECK BULLET/METEOR COLLISION
296 IF PEEK(C23) > 0 THEN GOSUB 600
297 IF PEEK(C24) > 0 THEN GOSUB 1250
300 REM   RESPAWN DEAD METEORS
301 FOR I=0 TO LV - 1
302 IF MA(I) = 0 THEN MA(I)=INT(RND(1) * 15) + 5:MX(I)=INT(RND(1) * 304) + 168:MY(I)=40:GOSUB 3010
303 NEXT I
310 IF LV3 <= 0 THEN GOTO 810
320 PAUSE SPD
330 GOTO 200
400 REM   --- END MAIN LOOP ---
500 REM   --- HUD UPDATE ---
501 SC$="LV:" + STR$(LV) + " LF:" + STR$(LV3) + " SC:" + STR$(SCC) + " NX:" + STR$(NXT) + "   "
502 FOR I=0 TO LEN(SC$) - 1
503 CV=ASC(MID$(SC$,I + 1,1))
504 IF CV >= 65 AND CV <= 90 THEN CV=CV - 64
505 POKE SC + I,CV:POKE CR + I,1
506 NEXT I
510 RETURN
600 REM   --- BULLET HIT METEOR ---
601 REM   FIND WHICH METEOR WAS HIT VIA POSITION CHECK
602 HI=PEEK(H23) - 1:REM   HIT SPRITE INDEX (1-10 = meteors 0-9)
603 IF HI < 0 OR HI > 9 THEN RETURN
604 I=HI
605 REM   FIND WHICH BULLET
606 FOR J=0 TO 4
607 IF BA(J) = 1 THEN GOTO 612
608 NEXT J
609 RETURN
612 BA(J)=0
613 GOSUB 3100:REM   HIDE BULLET
614 GOSUB 3200:REM   SHOW EXPLOSION AT METEOR POS
615 GOSUB 1700:REM   SFX
616 PAUSE 0.05
617 GOSUB 3210:REM   HIDE EXPLOSION
618 MA(I)=0:GOSUB 3050
619 SCC=SCC + 1
620 NXT=NXT - 1
621 IF NXT <= 0 THEN GOSUB 1000
622 GOSUB 500
623 RETURN
700 REM   --- METEOR HIT PLAYER ---
701 GOSUB 3200:REM   EXPLOSION AT PLAYER
702 GOSUB 1800:REM   SFX
703 PAUSE 0.1
704 GOSUB 3210
705 MA(I)=0:GOSUB 3050
706 LV3=LV3 - 1
707 IF LV3 <= 0 THEN RETURN
708 PX=320:PY=360
709 GOSUB 3000:REM   REDRAW PLAYER
710 GOSUB 500
711 RETURN
760 REM   --- METEOR PASSED BOTTOM ---
761 MA(I)=0
762 GOSUB 3050:REM   HIDE METEOR I
763 LV3=LV3 - 1
764 IF LV3 <= 0 THEN RETURN
765 GOSUB 500
766 RETURN
810 REM  --- GAME OVER ---
811 GOSUB 2100
812 POKE VB,0
813 POKE 49200 + 34,0
814 CLS
815 PRINT ""
816 PRINT ""
817 PRINT ""
818 PRINT "                           ***********************"
819 PRINT "                           *                     *"
820 PRINT "                           *     GAME  OVER      *"
821 PRINT "                           *                     *"
822 SC$=STR$(SCC)
823 PRINT "                           *  SCORE: " + SC$
824 LV$=STR$(LV)
825 PRINT "                           *  LEVEL: " + LV$
826 PRINT "                           *                     *"
827 PRINT "                           ***********************"
828 PRINT ""
829 PRINT "                           RETURNING TO TITLE..."
830 FOR WT=1 TO 20:PAUSE 1:NEXT WT
831 GOTO 1
850 REM   --- FIRE ---
851 FOR J=0 TO 4
852 IF BA(J) = 0 THEN BX(J)=PX:BY(J)=PY - 16:BA(J)=1:GOSUB 3080:GOSUB 1600:GOTO 870
853 NEXT J
870 RETURN
900 REM   --- MOVE LEFT ---
901 IF PX <= 168 THEN RETURN
902 PX=PX - 4
903 GOSUB 3000
910 RETURN
950 REM   --- MOVE RIGHT ---
951 IF PX >= 472 THEN RETURN
952 PX=PX + 4
953 GOSUB 3000
960 RETURN
1000 REM   --- LEVEL UP ---
1001 LV=LV + 1
1002 GOSUB 2000
1003 NXT=LV * 5
1004 FOR I=0 TO LV - 1
1005 IF MA(I) = 0 THEN MX(I)=INT(RND(1) * 304) + 168:MY(I)=40:MA(I)=INT(RND(1) * 20) + 10
1006 MS(I)=LV + 1
1007 NEXT I
1008 GOSUB 500
1009 RETURN
1100 REM   --- SPAWN BONUS SAUCER ---
1101 SHT=INT(RND(1) * 200) + 100
1102 SHD=INT(RND(1) * 2)
1103 IF SHD = 0 THEN SHD=- 1
1104 IF SHD = 1 THEN SHX=168
1105 IF SHD = - 1 THEN SHX=472
1106 SHA=1
1107 GOSUB 3300:REM   SHOW SAUCER
1108 RETURN
1150 REM   --- MOVE BONUS SAUCER ---
1151 SHX=SHX + SHD * 3
1152 IF SHX < 168 OR SHX > 472 THEN SHA=0:GOSUB 3310:RETURN
1153 GOSUB 3300
1154 RETURN
1250 REM   --- BULLET HIT SAUCER ---
1251 FOR J=0 TO 4
1252 IF BA(J) = 1 THEN GOTO 1255
1253 NEXT J
1254 RETURN
1255 BA(J)=0
1256 GOSUB 3100
1257 GOSUB 3320:REM   EXPLOSION AT SAUCER
1258 GOSUB 1900:REM   SFX
1259 PAUSE 0.1
1260 GOSUB 3330
1261 SHA=0
1262 GOSUB 3310
1263 IF LV3 < 5 THEN LV3=LV3 + 1
1264 GOSUB 500
1265 RETURN
1400 REM   --- SPAWN ALL METEORS ---
1401 FOR I=0 TO LV - 1
1402 MX(I)=INT(RND(1) * 304) + 168
1403 MY(I)=40 + I * 30
1404 MA(I)=I * 10 + 1
1405 MS(I)=2
1406 GOSUB 3010
1407 NEXT I
1408 RETURN
1500 REM   --- SOUND INIT ---
1501 POKE SB + 24,15
1502 POKE SB + 5,9:POKE SB + 6,0:POKE SB + 3,8
1503 POKE SB + 12,9:POKE SB + 13,0:POKE SB + 10,8
1504 POKE SB + 19,9:POKE SB + 20,0:POKE SB + 17,8
1505 RETURN
1600 REM   --- SFX FIRE ---
1601 POKE SB + 15,35
1602 POKE SB + 18,33
1603 PAUSE 0.02
1604 POKE SB + 18,32
1605 RETURN
1700 REM   --- SFX EXPLODE ---
1701 POKE SB + 7,0:POKE SB + 8,15
1702 POKE SB + 11,129
1703 PAUSE 0.05
1704 POKE SB + 11,128
1705 RETURN
1800 REM   --- SFX SHIP HIT ---
1801 POKE SB + 0,0:POKE SB + 1,8
1802 POKE SB + 4,129
1803 PAUSE 0.08
1804 POKE SB + 1,3
1805 PAUSE 0.08
1806 POKE SB + 4,128
1807 RETURN
1900 REM   --- SFX BONUS HIT ---
1901 POKE SB + 1,15:POKE SB + 4,65:PAUSE 0.05
1902 POKE SB + 1,20:PAUSE 0.05
1903 POKE SB + 1,25:PAUSE 0.05
1904 POKE SB + 4,64
1905 RETURN
2000 REM   --- SFX LEVEL UP ---
2001 POKE SB + 1,16:POKE SB + 4,65:PAUSE 0.05
2002 POKE SB + 1,22:PAUSE 0.05
2003 POKE SB + 1,28:PAUSE 0.1
2004 POKE SB + 4,64
2005 RETURN
2100 REM   --- SFX GAME OVER ---
2101 POKE SB + 4,0:PAUSE 0.05
2102 POKE SB + 1,15:POKE SB + 4,33
2103 PAUSE 0.15
2104 POKE SB + 1,10:PAUSE 0.15
2105 POKE SB + 1,5:PAUSE 0.15
2106 POKE SB + 4,32
2107 RETURN
3000 REM   --- DRAW PLAYER SPRITE ---
3001 O=0:REM   SPRITE 0
3002 POKE SS + 0,PX AND 255
3003 POKE SS + 1,INT(PX / 256)
3004 POKE SS + 2,PY AND 255
3005 POKE SS + 3,INT(PY / 256)
3006 POKE SS + 4,0:REM   TILE 0 SHIP
3007 POKE SS + 5,5:REM   COLOR GREEN
3008 POKE SS + 6,1 + 0 + 64:REM   ENABLED + GROUP1 + SINGLE COLOR = 65
3009 RETURN
3010 REM   --- DRAW METEOR I ---
3011 O=I + 1 * 8
3012 POKE SS + O + 0,MX(I) AND 255
3013 POKE SS + O + 1,INT(MX(I) / 256)
3014 POKE SS + O + 2,MY(I) AND 255
3015 POKE SS + O + 3,INT(MY(I) / 256)
3016 POKE SS + O + 4,1:REM   TILE 1 METEOR
3017 POKE SS + O + 5,0:REM   MULTICOLOR
3018 POKE SS + O + 6,1 + 32:REM   ENABLED + GROUP3 (BITS4-5=10=2 SO +32)
3019 RETURN
3050 REM   --- HIDE METEOR I ---
3051 O=I + 1 * 8
3052 POKE SS + O + 6,0:REM   DISABLE
3053 RETURN
3080 REM   --- DRAW BULLET J ---
3081 O=J + 11 * 8
3082 POKE SS + O + 0,BX(J) AND 255
3083 POKE SS + O + 1,INT(BX(J) / 256)
3084 POKE SS + O + 2,BY(J) AND 255
3085 POKE SS + O + 3,INT(BY(J) / 256)
3086 POKE SS + O + 4,2:REM   TILE 2 BULLET
3087 POKE SS + O + 5,1:REM   WHITE
3088 POKE SS + O + 6,1 + 16 + 64:REM   ENABLED + GROUP2 + SINGLE COLOR = 81
3089 RETURN
3100 REM   --- HIDE BULLET J ---
3101 O=J + 11 * 8
3102 POKE SS + O + 6,0
3103 RETURN
3200 REM   --- SHOW EXPLOSION AT METEOR/PLAYER POS ---
3201 O=I + 17 * 8
3202 POKE SS + O + 0,MX(I) AND 255
3203 POKE SS + O + 1,INT(MX(I) / 256)
3204 POKE SS + O + 2,MY(I) AND 255
3205 POKE SS + O + 3,INT(MY(I) / 256)
3206 POKE SS + O + 4,4:REM   TILE 5 EXPLOSION FRAME 1
3207 POKE SS + O + 5,0
3208 POKE SS + O + 6,1 + 8:REM   ENABLED + PRIORITY ABOVE TEXT
3209 RETURN
3210 REM   --- HIDE EXPLOSION ---
3211 O=I + 17 * 8
3212 POKE SS + O + 6,0
3213 RETURN
3300 REM   --- DRAW SAUCER ---
3301 O=16 * 8:REM   SPRITE 16
3302 POKE SS + O + 0,SHX AND 255
3303 POKE SS + O + 1,INT(SHX / 256)
3304 POKE SS + O + 2,48:REM   Y FIXED AT TOP
3305 POKE SS + O + 3,0
3306 POKE SS + O + 4,3:REM   TILE 3 SAUCER
3307 POKE SS + O + 5,0:REM   MULTICOLOR
3308 POKE SS + O + 6,1 + 48:REM   ENABLED + GROUP4 (BITS4-5=11=3 SO +48)
3309 RETURN
3310 REM   --- HIDE SAUCER ---
3311 O=16 * 8
3312 POKE SS + O + 6,0
3313 RETURN
3320 REM   --- EXPLOSION AT SAUCER ---
3321 O=27 * 8:REM   SPRITE 27
3322 POKE SS + O + 0,SHX AND 255
3323 POKE SS + O + 1,INT(SHX / 256)
3324 POKE SS + O + 2,48
3325 POKE SS + O + 3,0
3326 POKE SS + O + 4,4
3327 POKE SS + O + 5,0
3328 POKE SS + O + 6,1 + 8
3329 RETURN
3330 REM   --- HIDE SAUCER EXPLOSION ---
3331 O=27 * 8
3332 POKE SS + O + 6,0
3333 RETURN
4000 REM  --- OPENING SCREEN ---
4001 CLS
4002 POKE 49154,2
4003 DLOAD "MUSIC.BIN",65536
4004 POKE 49152,4
4005 POKE 49200 + 32,2:POKE 49200 + 33,0:POKE 49200 + 35,1
4006 POKE 49200 + 36,PEEK(32768):POKE 49200 + 37,PEEK(32769)
4007 POKE 49152,0
4008 POKE 49200 + 38,0
4009 POKE 49200 + 34,2
4010 PRINT ""
4011 PRINT ""
4012 PRINT ""
4013 PRINT "                           ***********************"
4014 PRINT "                           *                     *"
4015 PRINT "                           *   S T O R M  V D P  *"
4016 PRINT "                           *                     *"
4017 PRINT "                           *  DEFEND EARTH FROM  *"
4018 PRINT "                           *  THE METEOR STORM!  *"
4019 PRINT "                           *                     *"
4020 PRINT "                           *  JOYSTICK 1 TO MOVE *"
4021 PRINT "                           *  FIRE A TO SHOOT    *"
4022 PRINT "                           *  SHOOT THE SAUCER   *"
4023 PRINT "                           *  FOR AN EXTRA LIFE! *"
4024 PRINT "                           *                     *"
4025 PRINT "                           ***********************"
4026 PRINT ""
4027 PRINT "                             PRESS FIRE TO BEGIN"
4028 GET K$:IF K$ = "" THEN J=PEEK(49184):IF J AND 16 THEN GOTO 4040
4029 IF K$ = "" THEN GOTO 4028
4030 POKE 49154,0:REM  BORDER BACK TO BLACK
4031 RETURN
4040 POKE 49200 + 34,0
4041 POKE 49154,0
4042 RETURN
5000 REM   --- INIT TILEMAP ---
5001 FOR I=0 TO 999
5002 POKE TM + I,6:REM   STARFIELD
5003 NEXT I
5004 REM   LEFT BORDER COLUMN
5005 FOR R=0 TO 24
5006 POKE TM + R * 40 + 9,7
5007 NEXT R
5008 REM   RIGHT BORDER COLUMN
5009 FOR R=0 TO 24
5010 POKE TM + R * 40 + 30,7
5011 NEXT R
5012 RETURN
5100 REM   --- INIT ALL SPRITES DISABLED ---
5101 FOR I=0 TO 27
5102 POKE SS + I * 8 + 6,0
5103 NEXT I
5104 GOSUB 3000:REM   DRAW PLAYER AT START POS
5105 RETURN
5200 REM   --- SOUND INIT ---
5201 POKE SB + 24,15
5202 POKE SB + 5,9:POKE SB + 6,0:POKE SB + 3,8
5203 POKE SB + 12,9:POKE SB + 13,0:POKE SB + 10,8
5204 POKE SB + 19,9:POKE SB + 20,0:POKE SB + 17,8
5205 RETURN
