85 POKE SC + I,CV:POKE CR + I,1
86 NEXT I
87 GOSUB 500
88 GOSUB 1500
89 GOTO 163
91 POKE SC + I,CV:POKE CR + I,1
92 NEXT I
110 REM    --- SPAWN ALL ---
140 FOR I=0 TO LV - 1
142 MX(I)=INT(RND(1) * 40) + 20
144 MY(I)=2
146 MA(I)=I * 10 + 1
148 NEXT I
150 RETURN
160 REM    --- MAIN LOOP ---
162 REM     --- BONUS SHIP TIMER ---
163 SHT=SHT - 1
164 IF SHT <= 0 AND SHA = 0 THEN GOSUB 1100
165 IF SHA = 1 THEN GOSUB 1150
170 J=PEEK(JY)
180 IF J AND 4 THEN GOSUB 900
190 IF J AND 8 THEN GOSUB 950
200 IF J AND 16 THEN GOSUB 850
210 REM      --- MOVE SHOTS ---
215 FOR J=0 TO 4
220 IF BA(J) = 0 THEN GOTO 278
230 POKE SC + BY(J) * 80 + BX(J),32
240 BY(J)=BY(J) - 2
250 IF BY(J) < 1 THEN BA(J)=0:GOTO 278
260 POKE SC + BY(J) * 80 + BX(J),58
270 POKE CR + BY(J) * 80 + BX(J),7
278 NEXT J
280 REM      --- METEORS ---
290 FOR I=0 TO LV - 1
295 IF MA(I) = 1 THEN POKE SC + MY(I) * 80 + MX(I),32
300 IF MA(I) = 0 THEN GOTO 390
305 IF MA(I) > 1 THEN MA(I)=MA(I) - 1:GOTO 390
310 MY(I)=MY(I) + 1
320 FOR J=0 TO 4
325 IF BA(J) = 0 THEN GOTO 340
330 IF MX(I) = BX(J) AND MY(I) >= BY(J) - 1 AND MY(I) <= BY(J) + 1 THEN GOSUB 600:GOTO 390
340 NEXT J
350 IF MX(I) = PX AND MY(I) >= 38 THEN GOSUB 700:GOTO 390
360 IF MY(I) >= 38 THEN GOSUB 760:GOTO 390
370 POKE SC + MY(I) * 80 + MX(I),160
380 POKE CR + MY(I) * 80 + MX(I),8
390 NEXT I
400 REM      --- RESPAWN DEAD ---
410 FOR I=0 TO LV - 1
420 IF MA(I) = 0 THEN MA(I)=INT(RND(1) * 15) + 5:MX(I)=INT(RND(1) * 40) + 20:MY(I)=2
430 NEXT I
440 IF LV3 <= 0 THEN GOTO 810
450 PAUSE SPD
460 GOTO 163
500 REM    --- SCORE UPDATE ---
505 SC$=STR$(LV) + " "
506 FOR I=0 TO LEN(SC$) - 1:POKE SC + 3 + I,ASC(MID$(SC$,I + 1,1)):NEXT I
507 SC$=STR$(LV3) + " "
508 FOR I=0 TO LEN(SC$) - 1:POKE SC + 8 + I,ASC(MID$(SC$,I + 1,1)):NEXT I
509 SC$=STR$(SCC) + "   "
511 FOR I=0 TO LEN(SC$) - 1:POKE SC + 13 + I,ASC(MID$(SC$,I + 1,1)):NEXT I
512 SC$=STR$(NXT) + " "
513 FOR I=0 TO LEN(SC$) - 1:POKE SC + 19 + I,ASC(MID$(SC$,I + 1,1)):NEXT I
580 RETURN
600 REM     --- METEOR HIT BY SHOT ---
605 POKE SC + BY(J) * 80 + BX(J),32
610 BA(J)=0
620 POKE SC + MY(I) * 80 + MX(I),42:POKE CR + MY(I) * 80 + MX(I),7
622 GOSUB 1700
625 PAUSE 0.05
630 POKE SC + MY(I) * 80 + MX(I),32
640 MA(I)=0
650 SCC=SCC + 1
660 NXT=NXT - 1
665 IF NXT <= 0 THEN GOSUB 1000
670 GOSUB 500
675 POKE SC + 39 * 80 + PX,30:POKE CR + 39 * 80 + PX,2
680 RETURN
700 REM      --- SHIP HIT ---
710 POKE SC + MY(I) * 80 + MX(I),32
720 POKE SC + 39 * 80 + PX,32
730 MA(I)=0
731 GOSUB 1800
740 LV3=LV3 - 1
742 IF LV3 <= 0 THEN RETURN
745 PX=INT(RND(1) * 40) + 20
748 GOSUB 500
749 POKE SC + 39 * 80 + PX,30:POKE CR + 39 * 80 + PX,2
750 RETURN
760 REM      --- METEOR BOTTOM ---
770 POKE SC + MY(I) * 80 + MX(I),32
772 MA(I)=0
774 LV3=LV3 - 1
776 IF LV3 <= 0 THEN RETURN
778 GOSUB 500
779 POKE SC + 39 * 80 + PX,30:POKE CR + 39 * 80 + PX,2
780 RETURN
810 REM      --- GAME OVER ---
811 GOSUB 2100
820 CLS
830 PRINT "GAME OVER! SCORE: "; SCC
840 PRINT "PRESS ANY KEY"
845 GET K$:IF K$ = "" THEN GOTO 845
846 GOTO 10
850 REM      --- FIRE ---
855 FOR J=0 TO 4
860 IF BA(J) = 0 THEN BX(J)=PX:BY(J)=37:BA(J)=1:GOSUB 1600:GOTO 890
865 NEXT J
890 RETURN
900 IF PX <= 20 THEN RETURN
910 POKE SC + 39 * 80 + PX,32
920 PX=PX - 1
930 POKE SC + 39 * 80 + PX,30:POKE CR + 39 * 80 + PX,2
940 RETURN
950 IF PX >= 60 THEN RETURN
960 POKE SC + 39 * 80 + PX,32
970 PX=PX + 1
975 POKE SC + 39 * 80 + PX,30:POKE CR + 39 * 80 + PX,2
980 RETURN
1000 REM      --- LEVEL UP ---
1010 LV=LV + 1
1011 GOSUB 2000
1020 NXT=LV * 5
1030 FOR I=0 TO LV - 1
1035 IF MA(I) = 0 THEN MX(I)=INT(RND(1) * 40) + 20:MY(I)=2
1040 IF MA(I) = 0 THEN MA(I)=INT(RND(1) * 20) + 10
1050 NEXT I
1060 GOSUB 500
1070 RETURN
1100 REM     --- SPAWN BONUS SHIP ---
1110 SHT=INT(RND(1) * 40) + 20
1120 SHD=INT(RND(1) * 2)
1125 IF SHD = 0 THEN SHD=- 1
1130 IF SHD = 1 THEN SHX=20
1135 IF SHD = - 1 THEN SHX=60
1140 SHA=1
1145 RETURN
1150 REM     --- MOVE BONUS SHIP ---
1160 POKE SC + 1 * 80 + SHX,32
1170 SHX=SHX + SHD
1180 IF SHX < 20 OR SHX > 60 THEN SHA=0:RETURN
1190 REM     --- SHOT HIT ---
1195 FOR J=0 TO 4
1197 IF BA(J) = 0 THEN GOTO 1210
1200 IF SHX = BX(J) AND BY(J) <= 2 THEN GOSUB 1250:RETURN
1210 NEXT J
1220 POKE SC + 1 * 80 + SHX,119
1230 POKE CR + 1 * 80 + SHX,14
1240 RETURN
1250 REM     --- BONUS SHIP HIT ---
1260 BA(J)=0
1265 POKE SC + 1 * 80 + SHX,42:POKE CR + 1 * 80 + SHX,7
1266 GOSUB 1900
1270 PAUSE 0.1
1275 POKE SC + 1 * 80 + SHX,32
1280 SHA=0
1290 IF LV3 < 5 THEN LV3=LV3 + 1
1295 GOSUB 500
1296 POKE SC + 39 * 80 + PX,30:POKE CR + 39 * 80 + PX,2
1300 RETURN
1400 REM     --- DRAW BORDER ---
1410 FOR I=1 TO 39
1420 POKE SC + I * 80 + 19,98
1425 POKE CR + I * 80 + 19,1
1430 POKE SC + I * 80 + 61,98
1435 POKE CR + I * 80 + 61,1
1440 NEXT I
1450 RETURN
1500 REM   --- SOUND INIT (PURE SID) ---
1505 POKE SB + 24,15:REM  MASTER VOLUME MAX
1510 POKE SB + 5,9:POKE SB + 6,0:POKE SB + 3,8:REM  V1 ADSR & PW
1520 POKE SB + 12,9:POKE SB + 13,0:POKE SB + 10,8:REM  V2 ADSR & PW
1530 POKE SB + 19,9:POKE SB + 20,0:POKE SB + 17,8:REM  V3 ADSR & PW
1540 RETURN
1541 POKE SB + 10,2:POKE SB + 11,12
1542 POKE SB + 13,9:POKE SB + 14,128
1545 POKE SB + 13,20:POKE SB + 14,64
1550 POKE SB + 19,10:POKE SB + 18,2
1555 POKE SB + 21,18:POKE SB + 22,80
1560 POKE SB + 24,12
1570 RETURN
1600 REM   --- SFX FIRE ---
1610 POKE SB + 15,35:REM  V3 FREQ HI
1620 POKE SB + 18,33:REM  SAW + GATE
1630 PAUSE 0.02
1640 POKE SB + 18,32:REM  GATE OFF
1650 RETURN
1700 REM   --- SFX EXPLODE ---
1710 POKE SB + 7,0:POKE SB + 8,15:REM  V2 FREQ
1720 POKE SB + 11,129:REM  NOISE + GATE
1730 PAUSE 0.05
1740 POKE SB + 11,128:REM  GATE OFF
1750 RETURN
1755 POKE SB + 10,2:POKE SB + 11,12
1756 POKE SB + 13,9:POKE SB + 14,128
1760 RETURN
