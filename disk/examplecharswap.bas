10 REM --- SETUP CUSTOM CHARACTER SET IN SAFE RAM ---
20 REM COPY ROM (PAGE 240 / $F000) TO RAM (PAGE 64 / $4000)
30 REM WE USE $4000 TO AVOID THE MMU BANKING WINDOW AT $8000
40 SR = 61440 : DST = 16384
50 PRINT "COPYING ROM FONT TO RAM $4000..."
60 FOR I = 0 TO 2047
70   V = PEEK(SR + I)
80   POKE DST + I, V
90 NEXT I
100 PRINT "COPY COMPLETE."

110 REM --- REDEFINE CHARACTER 'A' ---
120 REM 'A' IS SCREEN CODE 1. OFFSET IS 1 * 8 = 8 BYTES.
130 BASE = DST + 8
140 REM MAKE 'A' A SOLID BOX
150 POKE BASE + 0, 255
160 POKE BASE + 1, 129
170 POKE BASE + 2, 129
180 POKE BASE + 3, 129
190 POKE BASE + 4, 129
200 POKE BASE + 5, 129
210 POKE BASE + 6, 129
220 POKE BASE + 7, 255

230 REM --- SWITCH VIDEO CHIP TO NEW FONT ---
240 REM POINT CHARSET POINTER (49158) TO PAGE 64 ($4000)
250 POKE 49158, 64

260 REM --- TEST ---

280 PRINT "THE LETTER A IS NOW A BOX:"
290 PRINT "A"
300 PRINT "OTHER CHARACTERS ARE NORMAL:"
310 PRINT "B C D E F G"