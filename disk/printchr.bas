10 REM === CHARACTER SET VIEWER ===
20 CLS
30 R = 0
40 PRINT "--- PRINTING CHARACTERS 32 TO 255 ---"
50 PRINT ""
60 FOR I = 32 TO 255
70 REM PRINT NUMBER AND CHAR
80 PRINT I; ": "; CHR$(I)
90 R = R + 1
100 REM CHECK IF PAGE IS FULL (36 LINES)
110 IF R < 36 THEN 160
120 REM PAUSE FOR USER
130 PRINT "--- PRESS ENTER FOR MORE ---";
140 INPUT K$
150 CLS : R = 0
160 NEXT I
170 PRINT "DONE."