10 CLS
20 SC=1024:CR=55296
30 REM  --- INIT ---
40 DIM TX(100):DIM TY(100)
50 LN=5:DX=1:DY=0
60 FOR I=0 TO LN - 1
70 TX(I)=20 - I:TY(I)=20
80 NEXT I
90 C=5:HC=2
100 REM  --- FOOD ---
110 FX=INT(RND(1) * 78) + 1:FY=INT(RND(1) * 38) + 1
120 POKE SC + FY * 80 + FX,81:POKE CR + FY * 80 + FX,7
130 REM  --- MAIN LOOP ---
140 GET K$
150 IF K$ = "W" AND DY = 0 THEN DX=0:DY=- 1
160 IF K$ = "S" AND DY = 0 THEN DX=0:DY=1
170 IF K$ = "A" AND DX = 0 THEN DX=- 1:DY=0
180 IF K$ = "D" AND DX = 0 THEN DX=1:DY=0
190 REM  --- ERASE TAIL ---
200 POKE SC + TY(LN - 1) * 80 + TX(LN - 1),32
210 REM  --- SHIFT TAIL ---
220 FOR I=LN - 1 TO 1 STEP - 1
230 TX(I)=TX(I - 1):TY(I)=TY(I - 1)
240 NEXT I
250 REM  --- MOVE HEAD ---
260 TX(0)=TX(0) + DX:TY(0)=TY(0) + DY
270 REM  --- WALL CHECK ---
280 IF TX(0) < 0 OR TX(0) > 79 OR TY(0) < 0 OR TY(0) > 39 THEN GOTO 420
290 REM  --- SELF COLLISION ---
300 FOR I=1 TO LN - 1
310 IF TX(0) = TX(I) AND TY(0) = TY(I) THEN GOTO 420
320 NEXT I
330 REM  --- FOOD CHECK ---
340 IF TX(0) = FX AND TY(0) = FY THEN GOSUB 500
350 REM  --- DRAW SNAKE ---
360 POKE SC + TY(0) * 80 + TX(0),81:POKE CR + TY(0) * 80 + TX(0),HC
370 FOR I=1 TO LN - 1
380 POKE SC + TY(I) * 80 + TX(I),79:POKE CR + TY(I) * 80 + TX(I),C
390 NEXT I
400 PAUSE 0.1
410 GOTO 140
420 REM  --- GAME OVER ---
430 CLS
440 PRINT "GAME OVER! LENGTH: "; LN
450 PRINT "PRESS ANY KEY TO PLAY AGAIN"
460 GET K$:IF K$ = "" THEN GOTO 460
470 GOTO 10
500 REM  --- EAT FOOD SUBROUTINE ---
510 LN=LN + 1
520 TX(LN - 1)=TX(LN - 2):TY(LN - 1)=TY(LN - 2)
530 FX=INT(RND(1) * 78) + 1:FY=INT(RND(1) * 38) + 1
540 POKE SC + FY * 80 + FX,81:POKE CR + FY * 80 + FX,7
550 RETURN
