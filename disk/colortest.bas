10 REM === 80-COLUMN PAINT TEST ===
20 CLS
30 PRINT "PAINTING SCREEN MEMORY..."
40 SC = 1024  : REM SCREEN RAM START
50 CR = 55296 : REM COLOR RAM START
60 W = 80     : REM SCREEN WIDTH
70 REM LOOP 1000 TIMES
80 FOR I = 1 TO 1000
90   X = INT(RND(1) * 80)
100  Y = INT(RND(1) * 40)
110  C = INT(RND(1) * 16)
120  OFFSET = (Y * W) + X
130  REM POKE SOLID BLOCK (160)
140  POKE SC + OFFSET, 160
150  REM POKE RANDOM COLOR
160  POKE CR + OFFSET, C
170 NEXT I
180 PRINT "DONE."