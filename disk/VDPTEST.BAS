1 REM VDPTEST.BAS - VDP HARDWARE TEST V3
2 REM SCREEN 640X400, SPRITES USE FULL 16-BIT X/Y
6 CLS
10 TB = 10240 : REM TILE DATA BASE ($2800)
20 TM = 9216  : REM TILEMAP BASE ($2400)
30 SS = 8192  : REM SMALL SPRITE TABLE ($2000)
40 LS = 8704  : REM LARGE SPRITE TABLE ($2200)
50 VB = 49280 : REM VDP REGISTER BASE ($C080)
60 PRINT "LOADING TILE DATA..."
100 REM TILE 1 - SOLID GREEN
150 FOR I = 0 TO 127
160 POKE TB + 128 + I, $55
170 NEXT I
200 REM TILE 2 - BLUE/CYAN CHECKERBOARD
260 FOR ROW = 0 TO 15
270 FOR COL = 0 TO 7
280 OFFSET = ROW * 8 + COL
290 IF (ROW + COL) / 2 = INT((ROW + COL) / 2) THEN B = $6E
300 IF (ROW + COL) / 2 <> INT((ROW + COL) / 2) THEN B = $E6
310 POKE TB + 256 + OFFSET, B
320 NEXT COL
330 NEXT ROW
400 REM TILE 3 - SINGLE COLOR SHIP (ALL $77)
450 FOR I = 0 TO 127
460 POKE TB + 384 + I, 0
470 NEXT I
500 DATA 0,0,0,0,0,0,0,0
510 DATA 0,0,0,0,0,0,0,0
520 DATA 0,0,0,0,0,0,0,0
530 DATA 0,0,0,119,119,0,0,0
540 DATA 0,0,119,119,119,119,0,0
550 DATA 0,119,119,119,119,119,119,0
560 DATA 119,119,119,119,119,119,119,119
570 DATA 119,119,119,119,119,119,119,119
580 DATA 0,119,119,119,119,119,119,0
590 DATA 0,0,119,119,119,119,0,0
600 DATA 0,0,0,119,119,0,0,0
610 DATA 0,0,0,0,0,0,0,0
620 DATA 0,0,0,0,0,0,0,0
630 DATA 0,0,0,0,0,0,0,0
640 DATA 0,0,0,0,0,0,0,0
650 DATA 0,0,0,0,0,0,0,0
660 FOR I = 0 TO 127
670 READ B
680 POKE TB + 384 + I, B
690 NEXT I
700 REM TILE 4 - MULTICOLOR SHIP
710 FOR I = 0 TO 127
720 POKE TB + 512 + I, 0
730 NEXT I
740 DATA 0,0,0,0,0,0,0,0
750 DATA 0,0,0,0,0,0,0,0
760 DATA 0,0,0,0,0,0,0,0
770 DATA 0,0,0,114,114,0,0,0
780 DATA 0,0,114,114,37,37,0,0
790 DATA 0,114,114,37,37,53,53,0
800 DATA 114,114,37,37,53,53,119,119
810 DATA 114,114,37,37,53,53,119,119
820 DATA 0,114,114,37,37,53,53,0
830 DATA 0,0,114,114,37,37,0,0
840 DATA 0,0,0,114,114,0,0,0
850 DATA 0,0,0,0,0,0,0,0
860 DATA 0,0,0,0,0,0,0,0
870 DATA 0,0,0,0,0,0,0,0
880 DATA 0,0,0,0,0,0,0,0
890 DATA 0,0,0,0,0,0,0,0
900 FOR I = 0 TO 127
910 READ B
920 POKE TB + 512 + I, B
930 NEXT I
940 PRINT "TILES LOADED."
950 PRINT "FILLING TILEMAP..."
960 FOR I = 0 TO 999
970 POKE TM + I, 1
980 NEXT I
990 FOR C = 0 TO 39
1000 POKE TM + C, 2
1010 POKE TM + (24 * 40) + C, 2
1020 NEXT C
1030 FOR R = 1 TO 23
1040 POKE TM + (R * 40), 2
1050 POKE TM + (R * 40) + 39, 2
1060 NEXT R
1070 PRINT "TILEMAP DONE."
1080 PRINT "SETTING UP SPRITES..."
1090 REM SPRITE 0 - SINGLE COLOR YELLOW MOVING GROUP 1
1100 REM FLAGS 81 = 1(ENABLE) + 16(GROUP1) + 64(SINGLE COLOR)
1110 SX = 160 : SY = 200
1120 POKE SS + 0, SX AND 255
1130 POKE SS + 1, INT(SX / 256)
1140 POKE SS + 2, SY AND 255
1150 POKE SS + 3, INT(SY / 256)
1160 POKE SS + 4, 3
1170 POKE SS + 5, 7
1180 POKE SS + 6, 81
1190 REM SPRITE 1 - MULTICOLOR CENTER SCREEN GROUP 2
1200 REM FLAGS 33 = 1(ENABLE) + 32(GROUP2) NO BIT6 = MULTICOLOR
1210 POKE SS + 8,  312 AND 255
1220 POKE SS + 9,  INT(312 / 256)
1230 POKE SS + 10, 200 AND 255
1240 POKE SS + 11, INT(200 / 256)
1250 POKE SS + 12, 4
1260 POKE SS + 13, 0
1270 POKE SS + 14, 33
1280 PRINT "SPRITES SET."
1290 POKE VB, 1
1300 POKE VB + 3, 1
1310 POKE VB + 7, 0
1320 PRINT "VDP ON."
1330 PRINT "SPRITE 0=SINGLE COLOR YELLOW"
1340 PRINT "SPRITE 1=MULTICOLOR"
1350 PRINT "PRESS ANY KEY TO STOP"
1400 DX = 2 : DY = 1
1410 SX = 160 : SY = 200
1500 GET A$
1510 IF A$ <> "" THEN GOTO 2000
1520 SX = SX + DX
1530 SY = SY + DY
1540 IF SX > 616 THEN DX = -DX : SX = 616
1550 IF SX < 24 THEN DX = -DX : SX = 24
1560 IF SY > 376 THEN DY = -DY : SY = 376
1570 IF SY < 24 THEN DY = -DY : SY = 24
1580 POKE SS + 0, SX AND 255
1590 POKE SS + 1, INT(SX / 256)
1600 POKE SS + 2, SY AND 255
1610 POKE SS + 3, INT(SY / 256)
1620 IF PEEK(49299) > 0 THEN GOSUB 3000
1630 PAUSE 0.02
1640 GOTO 1500
2000 PRINT "TESTING PALETTES..."
2010 FOR P = 0 TO 3
2020 POKE VB + 7, P
2030 PRINT "PALETTE "; P
2040 PAUSE 1.5
2050 NEXT P
2060 POKE VB + 7, 0
2100 PRINT "SCROLL TEST..."
2110 FOR S = 0 TO 255
2120 POKE VB + 1, S
2130 POKE VB + 2, S / 2
2140 PAUSE 0.02
2150 NEXT S
2160 POKE VB + 1, 0
2170 POKE VB + 2, 0
2200 PRINT "VDP TEST COMPLETE."
2210 PRINT "POKE 49280,0 TO RETURN TO TEXT MODE"
2220 END
3000 REM COLLISION - FLASH SPRITE 0 RED THEN BACK TO YELLOW
3010 PRINT "** COLLISION **"
3020 POKE SS + 5, 2
3030 PAUSE 0.1
3040 POKE SS + 5, 7
3050 RETURN
