10 REM === SCREEN SWAP DEMO ===
20 SP = 49157 : REM SCREEN POINTER REG
30 SC1 = 1024 : REM SCREEN 1 (PAGE 4)
40 SC2 = 8192 : REM SCREEN 2 (PAGE 32)
50 CR = 55296 : REM COLOR RAM (FIXED)
60 W = 80 : H = 40
70 CLS
80 PRINT "PREPARING HIDDEN SCREEN..."

90 REM --- STEP 1: CLEAR SCREEN 2 MEMORY ---
100 REM WE MUST FILL IT WITH SPACES (32)
110 FOR I = 0 TO 3199
120   POKE SC2 + I, 32
130 NEXT I

140 REM --- STEP 2: DRAW ON SCREEN 1 (CORNERS) ---
150 REM TOP LEFT (RED)
160 POKE SC1, 160 : POKE CR, 2
170 REM TOP RIGHT (RED)
180 POKE SC1+79, 160 : POKE CR+79, 2
190 REM BOTTOM RIGHT (RED)
200 POKE SC1+3199, 160 : POKE CR+3199, 2
210 REM BOTTOM LEFT (RED)
220 POKE SC1+3120, 160 : POKE CR+3120, 2

230 REM --- STEP 3: DRAW ON SCREEN 2 (CENTER) ---
240 REM CENTER OFFSET = (20 * 80) + 40 = 1640
250 MID = 1640
260 REM BIG GREEN SQUARE
270 POKE SC2 + MID, 160     : POKE CR + MID, 5
280 POKE SC2 + MID + 1, 160 : POKE CR + MID + 1, 5
290 POKE SC2 + MID + 80, 160: POKE CR + MID + 80, 5
300 POKE SC2 + MID + 81, 160: POKE CR + MID + 81, 5

310 REM --- STEP 4: THE SWAP LOOP ---
320 PRINT "SWAPPING IN 2 SECONDS..."
330 PAUSE 2
340 REM SWAP TO SCREEN 2 (PAGE 32)
350 POKE SP, 32
360 PAUSE 2
370 REM SWAP BACK TO SCREEN 1 (PAGE 4)
380 POKE SP, 4
390 PRINT "DONE."